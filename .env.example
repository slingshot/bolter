# S3/R2 Storage (required)
# S3_BUCKET=your-bucket-name
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_USE_PATH_STYLE_ENDPOINT=true
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Redis (optional - uses local Redis container by default)
# REDIS_URL=redis://localhost:6379

# Server
# PORT=3001
# BASE_URL=http://localhost:3001
# NODE_ENV=production
# DETECT_BASE_URL=true

# Limits (optional - sensible defaults provided)
# MAX_FILE_SIZE=1000000000000        # 1 TB
# MAX_FILES_PER_ARCHIVE=64
# MAX_EXPIRE_SECONDS=15552000        # 6 months
# MAX_DOWNLOADS=100

# Defaults (optional)
# DEFAULT_EXPIRE_SECONDS=86400       # 1 day
# DEFAULT_DOWNLOADS=1
# EXPIRE_TIMES_SECONDS=300,3600,86400,604800,1209600,2592000,7776000,15552000
# DOWNLOAD_COUNTS=1,2,3,4,5,20,50,100

# UI Customization (optional)
# CUSTOM_TITLE=Slingshot Send
# CUSTOM_DESCRIPTION=Encrypt and send files with a link that automatically expires.

# Frontend build args (optional)
# VITE_APP_TITLE=Slingshot Send
# VITE_APP_DESCRIPTION=Encrypt and send files with a link that automatically expires.
