{
    "$schema": "https://turborepo.dev/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"],
            "env": [
                "NODE_ENV",
                "VITE_APP_TITLE",
                "VITE_APP_DESCRIPTION",
                "VITE_API_URL",
                "SENTRY_ORG",
                "SENTRY_PROJECT",
                "SENTRY_AUTH_TOKEN"
            ]
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": ["^build"]
        },
        "start": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^build"]
        }
    },
    "globalDependencies": [".env", ".env.*"],
    "globalPassThroughEnv": [
        "S3_BUCKET",
        "S3_ENDPOINT",
        "S3_USE_PATH_STYLE_ENDPOINT",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "REDIS_URL",
        "PORT",
        "BASE_URL",
        "DETECT_BASE_URL",
        "MAX_FILE_SIZE",
        "MAX_FILES_PER_ARCHIVE",
        "MAX_EXPIRE_SECONDS",
        "MAX_DOWNLOADS",
        "DEFAULT_EXPIRE_SECONDS",
        "DEFAULT_DOWNLOADS",
        "EXPIRE_TIMES_SECONDS",
        "DOWNLOAD_COUNTS",
        "CUSTOM_TITLE",
        "CUSTOM_DESCRIPTION"
    ]
}
