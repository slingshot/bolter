{
    "name": "bolter-monorepo",
    "private": true,
    "workspaces": [
        "frontend",
        "backend",
        "shared"
    ],
    "scripts": {
        "dev": "bunx dotenvx run -f .env* -- bun run --cwd backend dev & bun run --cwd frontend dev",
        "dev:frontend": "bun run --cwd frontend dev",
        "dev:backend": "bunx dotenvx run -f .env* -- bun run --cwd backend dev",
        "build": "bun run --cwd frontend build && bun run --cwd backend build",
        "build:frontend": "bun run --cwd frontend build",
        "build:backend": "bun run --cwd backend build",
        "start": "bunx dotenvx run -f .env* -- bun run --cwd backend start & bun run --cwd frontend preview",
        "start:frontend": "bun run --cwd frontend preview",
        "start:backend": "bunx dotenvx run -f .env* -- bun run --cwd backend start",
        "install:all": "cd frontend && bun install && cd ../backend && bun install",
        "lint": "bunx biome lint .",
        "lint:fix": "bunx biome lint --write .",
        "format": "bunx biome format --write .",
        "check": "bunx biome check --write .",
        "commit": "cz",
        "prepare": "lefthook install"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "trustedDependencies": [
        "lefthook"
    ],
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@commitlint/types": "^20.4.0",
        "@dotenvx/dotenvx": "^1.51.4",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "lefthook": "^2.1.2"
    },
    "dependencies": {
        "@vercel/analytics": "^1.6.1"
    }
}
